name: 🚀 Feature request
description: Suggest a new feature or enhancement
title: "[Feature]: "
labels: ["enhancement"]

body:
  - type: markdown
    attributes:
      value: |
        Please provide enough detail for this to be properly considered.

        Low-effort or vague requests may be closed.

  - type: textarea
    id: problem
    attributes:
      label: What problem does this solve?
      description: Describe the use case
    validations:
      required: true

  - type: textarea
    id: solution
    attributes:
      label: Proposed solution
    validations:
      required: true

  - type: textarea
    id: alternatives
    attributes:
      label: Alternatives considered
      description: Have you tried any workarounds?

  - type: textarea
    id: additional
    attributes:
      label: Additional context
